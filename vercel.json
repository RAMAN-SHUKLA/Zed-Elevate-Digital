{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*).(js|css|png|jpg|jpeg|svg|webp|xml|txt)", "dest": "/$1.$2" },
    { "src": "/blog-kanpur-invisible-google.html", "dest": "/blog-kanpur-invisible-google.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
